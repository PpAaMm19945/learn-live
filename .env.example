# Learn Live Frontend Environment Variables
# Copy this file to .env and fill in the values

# API URL for the Cloudflare Worker Backend (or Cloud Run agent locally)
# Local development:
VITE_API_URL=http://localhost:8787
# Production:
# VITE_API_URL=https://api.yourdomain.com

# --- Future Gemini/GCP configurations if needed client side ---
# It is generally discouraged to expose these to the client, but keeping placeholders.
# VITE_GEMINI_API_KEY=
# VITE_WEBSOCKET_URL=ws://localhost:8080
