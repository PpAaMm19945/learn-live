# Learn Live Frontend Environment Variables
# Copy this file to .env and fill in the values

# API URL for the Cloudflare Worker Backend
# Local development:
VITE_WORKER_URL=http://localhost:8787
# Production (set in .env.production):
# VITE_WORKER_URL=https://learn-live.antmwes104-1.workers.dev

# WebSocket URL for the Agent (Cloud Run)
# VITE_AGENT_WS_URL=ws://localhost:8080
VITE_AGENT_URL=https://learnlive-agent-XXXXX.run.app
